DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
# DATABASE_URL=postgresql://nexora:change-me@db:5432/nexora
POSTGRES_SSLMODE=prefer
DJANGO_CACHE_URL=redis://cache:6379/1
DJANGO_LOG_LEVEL=INFO
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-smtp-username
EMAIL_HOST_PASSWORD=replace-with-smtp-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=NEXORA <noreply@example.com>
# Keep this secret only in .env; it is never sent to the browser.
GEMINI_API_KEY=replace-with-google-ai-studio-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_ENABLED=False
EMAIL_VERIFICATION_EXPIRY_SECONDS=600
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN=60
EMAIL_VERIFICATION_MAX_SENDS_PER_HOUR=5
SIGNUP_RATE_LIMIT_PER_IP=10
SIGNUP_RATE_LIMIT_PER_EMAIL=3
SIGNUP_RATE_LIMIT_WINDOW=3600
VERIFICATION_RECOVERY_RATE_LIMIT_PER_IP=10
VERIFICATION_RECOVERY_RATE_LIMIT_PER_EMAIL=5
VERIFICATION_RECOVERY_RATE_LIMIT_WINDOW=3600
LOGIN_RATE_LIMIT_PER_IP=10
LOGIN_RATE_LIMIT_PER_ACCOUNT=5
LOGIN_RATE_LIMIT_WINDOW=900
ADMIN_LOGIN_RATE_LIMIT_PER_IP=10
ADMIN_LOGIN_RATE_LIMIT_PER_ACCOUNT=5
ADMIN_LOGIN_RATE_LIMIT_WINDOW=900
PASSWORD_RESET_RATE_LIMIT_PER_IP=5
PASSWORD_RESET_RATE_LIMIT_PER_ACCOUNT=3
PASSWORD_RESET_RATE_LIMIT_WINDOW=3600
