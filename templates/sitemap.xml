<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xhtml="http://www.w3.org/1999/xhtml">
<url><loc>{{ site_url }}/</loc><xhtml:link rel="alternate" hreflang="ka" href="{{ site_url }}/"/><xhtml:link rel="alternate" hreflang="en" href="{{ site_url }}/en/"/><xhtml:link rel="alternate" hreflang="ru" href="{{ site_url }}/ru/"/><xhtml:link rel="alternate" hreflang="x-default" href="{{ site_url }}/"/><changefreq>daily</changefreq><priority>1.0</priority></url>
<url><loc>{{ site_url }}/shop/</loc><xhtml:link rel="alternate" hreflang="ka" href="{{ site_url }}/shop/"/><xhtml:link rel="alternate" hreflang="en" href="{{ site_url }}/en/shop/"/><xhtml:link rel="alternate" hreflang="ru" href="{{ site_url }}/ru/shop/"/><xhtml:link rel="alternate" hreflang="x-default" href="{{ site_url }}/shop/"/><changefreq>daily</changefreq><priority>0.9</priority></url>
{% for category in categories %}<url><loc>{{ site_url }}/shop/?category={{ category.slug }}</loc><xhtml:link rel="alternate" hreflang="ka" href="{{ site_url }}/shop/?category={{ category.slug }}"/><xhtml:link rel="alternate" hreflang="en" href="{{ site_url }}/en/shop/?category={{ category.slug }}"/><xhtml:link rel="alternate" hreflang="ru" href="{{ site_url }}/ru/shop/?category={{ category.slug }}"/><xhtml:link rel="alternate" hreflang="x-default" href="{{ site_url }}/shop/?category={{ category.slug }}"/><changefreq>weekly</changefreq><priority>0.7</priority></url>{% endfor %}
{% for product in products %}<url><loc>{{ site_url }}/product/{{ product.slug }}/</loc><xhtml:link rel="alternate" hreflang="ka" href="{{ site_url }}/product/{{ product.slug }}/"/><xhtml:link rel="alternate" hreflang="en" href="{{ site_url }}/en/product/{{ product.slug }}/"/><xhtml:link rel="alternate" hreflang="ru" href="{{ site_url }}/ru/product/{{ product.slug }}/"/><xhtml:link rel="alternate" hreflang="x-default" href="{{ site_url }}/product/{{ product.slug }}/"/>{% if product.updated_at %}<lastmod>{{ product.updated_at|date:'Y-m-d' }}</lastmod>{% endif %}<changefreq>weekly</changefreq><priority>0.8</priority></url>{% endfor %}
</urlset>